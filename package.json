{
  "name": "video-chapters",
  "version": "1.0.0",
  "description": "Offline chapter markers for local video files",
  "main": "main.js",
  "author": "William Slabbaert",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.williamslabbaert.videochapters",
    "productName": "Video Chapters",
    "files": ["**/*", "!dist/**"],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
